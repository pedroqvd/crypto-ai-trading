# ================================================
# POLYMARKET AI TRADER — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ================================================

# ------------------------------------------------
# WALLET (Polygon Mainnet)
# ------------------------------------------------
# Chave privada da carteira Polygon com saldo em USDC.e
# NUNCA commite este valor no git
PRIVATE_KEY=0x...

# ------------------------------------------------
# MODO DE OPERAÇÃO
# ------------------------------------------------
# true  = simulação (recomendado para testar)
# false = trades reais na Polymarket
DRY_RUN=true

# ------------------------------------------------
# CAPITAL
# ------------------------------------------------
# Bankroll inicial em USDC (usado como referência base)
BANKROLL=1000

# ------------------------------------------------
# ESTRATÉGIA — Parâmetros do modelo
# ------------------------------------------------
# Fração Kelly: 0.25 = quarter-Kelly (conservador, recomendado)
KELLY_FRACTION=0.25

# Edge mínimo para considerar uma oportunidade (3% = 0.03)
MIN_EDGE=0.03

# Liquidez mínima do mercado em USDC
MIN_LIQUIDITY=5000

# Volume mínimo do mercado em USDC
MIN_VOLUME=10000

# Máximo % do bankroll por posição individual (5% = 0.05)
MAX_POSITION_PCT=0.05

# Máximo % do bankroll em exposição total simultânea (50% = 0.50)
MAX_TOTAL_EXPOSURE_PCT=0.50

# ------------------------------------------------
# GESTÃO DE POSIÇÃO
# ------------------------------------------------
# Saída antecipada: vende a posição quando o preço atinge este nível
# Ex: 0.85 = sai quando YES chega a 85% (lock in ~85% do potencial)
# Reduz exposição a reversões de última hora
EXIT_PRICE_TARGET=0.85

# Spread máximo bid-ask para aceitar um trade (3% = 0.03)
# Acima disso o custo de transação consome o edge
MAX_ORDER_SPREAD_PCT=0.03

# Mínimo de shares disponíveis no order book para entrar
# Evita trades sem liquidez real no CLOB
MIN_ORDER_BOOK_SHARES=5

# ------------------------------------------------
# TIMING
# ------------------------------------------------
# Intervalo entre scans de mercado em milissegundos
# 60000 = 60 segundos
SCAN_INTERVAL_MS=60000

# ------------------------------------------------
# DASHBOARD
# ------------------------------------------------
# Porta do servidor web do dashboard
DASHBOARD_PORT=3000

# Nível de log: debug | info | warn
LOG_LEVEL=info

# ------------------------------------------------
# NOTIFICAÇÕES (opcional)
# ------------------------------------------------
# URL do webhook do Discord para alertas
# Deixe vazio para desativar notificações Discord
DISCORD_WEBHOOK_URL=

# ------------------------------------------------
# INTEGRAÇÃO DE NOTÍCIAS (opcional)
# ------------------------------------------------
# Chave da API newsapi.org (plano grátis: 100 req/dia)
# Registre em: https://newsapi.org/register
# Quando configurada, o bot verifica notícias recentes antes
# de cada trade para confirmar ou rejeitar a tese de investimento
NEWS_API_KEY=

# Janela de relevância das notícias em horas (padrão: 6)
# Notícias mais antigas que isso são ignoradas
NEWS_RELEVANCE_HOURS=6

# ------------------------------------------------
# ANÁLISE DE CORRELAÇÃO (opcional)
# ------------------------------------------------
# Detecta inconsistências de preço entre mercados do mesmo evento
# Ex: soma dos candidatos numa eleição ≠ 100% → mispricing
# true = habilitado (recomendado), false = desabilitado
CORRELATION_ENABLED=true

# ------------------------------------------------
# INTEGRAÇÃO ORACLE CLOUD ↔ SITE (opcional)
# Preencha quando o frontend estiver num host separado do bot
# (ex: Vercel como frontend + Oracle Cloud como backend)
# ------------------------------------------------
# URL completa do backend Oracle Cloud (ex: http://1.2.3.4:3000)
# Deixe vazio quando frontend e backend rodam no mesmo host
ORACLE_BACKEND_URL=

# Origens CORS permitidas, separadas por vírgula
# Ex: https://meuapp.vercel.app,https://outro-dominio.com
# Deixe vazio para permitir qualquer origem (*)
ALLOWED_ORIGINS=

# ------------------------------------------------
# AUTENTICAÇÃO DO DASHBOARD
# Gerado automaticamente por: npx ts-node src/auth/setup.ts
# NÃO edite manualmente estes valores
# ------------------------------------------------
AUTH_EMAIL=
AUTH_PASSWORD_HASH=
JWT_SECRET=
