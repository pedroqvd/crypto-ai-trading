# ================================================
# POLYMARKET AI TRADER — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ================================================

# ------------------------------------------------
# WALLET (Polygon Mainnet)
# ------------------------------------------------
# Chave privada da carteira Polygon com saldo em USDC.e
# NUNCA commite este valor no git
# Obrigatória apenas quando DRY_RUN=false
PRIVATE_KEY=0x...

# ------------------------------------------------
# MODO DE OPERAÇÃO
# ------------------------------------------------
# true  = simulação sem dinheiro real (padrão seguro)
# false = trades reais na Polymarket (requer PRIVATE_KEY)
DRY_RUN=true

# ------------------------------------------------
# CAPITAL
# ------------------------------------------------
# Bankroll em USDC usado como base para Kelly sizing
BANKROLL=1000

# ------------------------------------------------
# ESTRATÉGIA — Kelly + Edge
# ------------------------------------------------
# Fração Kelly: 0.25 = quarter-Kelly (conservador, recomendado)
# Valores maiores = mais agressivo, mais risco
KELLY_FRACTION=0.25

# Edge mínimo para considerar uma oportunidade
# 0.01 = 1% (permissivo, mais trades), 0.05 = 5% (seletivo)
MIN_EDGE=0.01

# Liquidez mínima do mercado em USDC
MIN_LIQUIDITY=5000

# Volume mínimo do mercado em USDC
MIN_VOLUME=10000

# Máximo % do bankroll por posição individual (0.05 = 5%)
MAX_POSITION_PCT=0.05

# Máximo % do bankroll em exposição total simultânea (0.50 = 50%)
MAX_TOTAL_EXPOSURE_PCT=0.50

# ------------------------------------------------
# GESTÃO DE POSIÇÃO — Saída antecipada
# ------------------------------------------------
# Vende quando o preço atinge este nível (0.85 = 85¢)
# Lock in ganhos antes de possível reversão
EXIT_PRICE_TARGET=0.85

# Stop-loss: fecha posição se cair X% do preço de entrada (0.40 = 40%)
STOP_LOSS_PCT=0.40

# Trailing stop: ativa após X% de ganho (0.20 = 20%)
TRAILING_STOP_ACTIVATION=0.20

# Trailing stop: fecha se cair X% abaixo do pico (0.12 = 12%)
TRAILING_STOP_DISTANCE=0.12

# Time decay: fecha posições perdendo com menos de X horas para expirar
TIME_DECAY_HOURS=6

# Edge reversal: fecha se o mercado inverter a tese original
# true = habilitado (recomendado), false = desabilitado
EDGE_REVERSAL_ENABLED=true

# Saída por momentum: fecha após X ciclos consecutivos de queda
MOMENTUM_EXIT_CYCLES=3

# ------------------------------------------------
# ORDER BOOK
# ------------------------------------------------
# Spread máximo bid-ask para aceitar um trade (0.03 = 3%)
MAX_ORDER_SPREAD_PCT=0.03

# Mínimo de shares disponíveis no order book para entrar
MIN_ORDER_BOOK_SHARES=5

# ------------------------------------------------
# TIMING
# ------------------------------------------------
# Intervalo entre scans em milissegundos (60000 = 60s)
SCAN_INTERVAL_MS=60000

# ------------------------------------------------
# DASHBOARD
# ------------------------------------------------
DASHBOARD_PORT=3000
LOG_LEVEL=info

# ------------------------------------------------
# NOTIFICAÇÕES (opcional)
# ------------------------------------------------
DISCORD_WEBHOOK_URL=

# ------------------------------------------------
# ANÁLISE DE CORRELAÇÃO
# ------------------------------------------------
# Detecta inconsistências de preço entre mercados do mesmo evento
CORRELATION_ENABLED=true

# ------------------------------------------------
# CLAUDE AI — Gate de confirmação (opcional)
# ------------------------------------------------
# Quando habilitado, Claude confirma cada trade antes de executar
# Requer CLAUDE_API_KEY válida
CLAUDE_ENABLED=false
CLAUDE_API_KEY=
# Máximo de chamadas Claude por ciclo (evita custos excessivos)
CLAUDE_MAX_CALLS_PER_CYCLE=5

# ------------------------------------------------
# NOTÍCIAS (opcional)
# ------------------------------------------------
# Chave da API newsapi.org (plano grátis: 100 req/dia)
NEWS_API_KEY=
NEWS_RELEVANCE_HOURS=6

# ------------------------------------------------
# CALIBRAÇÃO E APRENDIZADO
# ------------------------------------------------
# Sistema de calibração bayesiana + ensemble learning
# false = desabilitado (útil para testes rápidos)
CALIBRATION_ENABLED=true

# ------------------------------------------------
# DEPLOY SPLIT (opcional)
# Preencha quando frontend e backend estão em hosts separados
# Ex: Vercel (frontend) + Fly.io (backend)
# ------------------------------------------------
# URL completa do backend (ex: https://meu-bot.fly.dev)
# Deixe vazio quando tudo roda no mesmo host
BACKEND_URL=

# Origens CORS permitidas (separadas por vírgula)
# Ex: https://meuapp.vercel.app
# Padrão: permite apenas localhost
ALLOWED_ORIGINS=

# ------------------------------------------------
# AUTENTICAÇÃO DO DASHBOARD
# Gerado automaticamente por: npx ts-node src/auth/setup.ts
# NÃO edite manualmente estes valores
# ------------------------------------------------
AUTH_EMAIL=
AUTH_PASSWORD_HASH=
JWT_SECRET=
